# FSAO Iris - Exemple de configuration backend
# Copier ce fichier vers backend/.env puis remplacer toutes les valeurs sensibles.

# Base de donnees
MONGO_URL=mongodb://localhost:27017
DB_NAME=fsao_iris

# Securite JWT - OBLIGATOIRE
# Generer une cle forte, par exemple : openssl rand -hex 32
SECRET_KEY=REMPLACER_PAR_UNE_CLE_FORTE_GENERÉE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# Documentation API protegee
DOCS_USER=admin
DOCS_PASS=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT

# Serveur backend
HOST=0.0.0.0
PORT=8001

# URLs applicatives
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8001
APP_URL=http://localhost:3000

# SMTP / emails
SMTP_SERVER=smtp.gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=votre.email@gmail.com
SMTP_PASSWORD=mot_de_passe_application
SMTP_SENDER_EMAIL=votre.email@gmail.com
SMTP_FROM=votre.email@gmail.com
SMTP_FROM_NAME=FSAO Iris
SMTP_USER=votre.email@gmail.com
SMTP_USE_TLS=true

# IA / LLM
# Renseigner uniquement les fournisseurs réellement utilisés.
EMERGENT_LLM_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Google Drive - sauvegardes optionnelles
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:8001/api/backup/drive/callback

# Notifications Push PWA - optionnel
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# Cameras / chiffrement - optionnel
CAMERA_ENCRYPTION_KEY=
